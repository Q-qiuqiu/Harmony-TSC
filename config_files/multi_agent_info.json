{
  "sub_agents": {
    "image_agent": {
      "description": "Image reasoning agent that selects an on-board vision model and triggers gateway execution.",
      "capabilities": [
        "object_detection",
        "image_classification",
        "image_reasoning"
      ],
      "startup_overhead": {
        "RK3588": {
          "cpu_usage": 0.03,
          "mem_usage": 0.02,
          "xpu_usage": 0.4
        },
        "ATLAS_L": {
          "cpu_usage": 0.04,
          "mem_usage": 0.03,
          "xpu_usage": 0.4
        },
        "ATLAS_H": {
          "cpu_usage": 0.04,
          "mem_usage": 0.03,
          "xpu_usage": 0.4
        }
      },
      "tools": {
        "YoloV5": {
          "task_type": "YoloV5",
          "tool_kind": "vision_model",
          "capabilities": [
            "object_detection",
            "multi_object_detection",
            "bounding_box_estimation"
          ],
          "description": "Fast object detection model for locating multiple targets in an image."
        },
        "ResNet50": {
          "task_type": "ResNet50",
          "tool_kind": "vision_model",
          "capabilities": [
            "image_classification",
            "single_label_classification"
          ],
          "description": "Image classification model with stronger accuracy but higher cost than MobileNet."
        },
        "MobileNet": {
          "task_type": "MobileNet",
          "tool_kind": "vision_model",
          "capabilities": [
            "image_classification",
            "lightweight_classification",
            "fast_inference"
          ],
          "description": "Lightweight image classification model optimized for speed and lower overhead."
        }
      },
      "runtime": {
        "RK3588": {
          "container_name": "image_agent_qwen3_1_7b",
          "image": "qwen3_1.7b_docker:latest",
          "startup_timeout_sec": 60,
          "cmds": [
            "bash",
            "/workspace/multi-agent/server/image_agent.sh"
          ],
          "args": [],
          "host_config_privileged": true,
          "env": [
            "PYTHONUNBUFFERED=1",
            "LLM_API_URL=http://127.0.0.1:8081/v1/chat/completions",
            "IMAGE_AGENT_PORT=8083",
            "RKLLM_MODEL_PATH=/models/Qwen3-1.7B-rk3588-w8a8.rkllm",
            "RKLLM_TARGET_PLATFORM=rk3588"
          ],
          "host_config_binds": [
            "/root/edge-cluster-scheduler/multi-agent:/workspace/multi-agent",
            "/root/edge-cluster-scheduler/config_files:/workspace/config_files",
            "/dev/dri:/dev/dri",
            "/proc/device-tree:/proc/device-tree:ro",
            "/root/models/Qwen3-1.7B-rk3588-w8a8.rkllm:/models/Qwen3-1.7B-rk3588-w8a8.rkllm"
          ],
          "devices": [],
          "host_ip": "0.0.0.0",
          "host_port": 8083,
          "container_port": 8083,
          "has_tty": false,
          "network_config": "bridge"
        }
      }
    },
    "text_agent": {
      "description": "Text reasoning agent that routes text requests to the on-board Bert service.",
      "capabilities": [
        "text_classification",
        "text_reasoning",
        "text_understanding"
      ],
      "startup_overhead": {
        "RK3588": {
          "cpu_usage": 0.03,
          "mem_usage": 0.02,
          "xpu_usage": 0.4
        }
      },
      "tools": {
        "Bert": {
          "task_type": "Bert",
          "tool_kind": "text_model",
          "capabilities": [
            "text_classification",
            "sentence_understanding",
            "semantic_matching"
          ],
          "description": "Bert text model deployed on Atlas nodes for text understanding requests."
        }
      },
      "runtime": {
        "RK3588": {
          "container_name": "text_agent_qwen3_1_7b",
          "image": "qwen3_1.7b_docker:latest",
          "startup_timeout_sec": 180,
          "cmds": [
            "bash",
            "/workspace/multi-agent/server/text_agent.sh"
          ],
          "args": [],
          "host_config_privileged": true,
          "env": [
            "PYTHONUNBUFFERED=1",
            "TEXT_AGENT_PORT=8085",
            "RKLLM_MODEL_PATH=/models/Qwen3-1.7B-rk3588-w8a8.rkllm",
            "RKLLM_TARGET_PLATFORM=rk3588"
          ],
          "host_config_binds": [
            "/root/edge-cluster-scheduler/multi-agent:/workspace/multi-agent",
            "/root/edge-cluster-scheduler/config_files:/workspace/config_files",
            "/dev/dri:/dev/dri",
            "/proc/device-tree:/proc/device-tree:ro",
            "/root/models/Qwen3-1.7B-rk3588-w8a8.rkllm:/models/Qwen3-1.7B-rk3588-w8a8.rkllm"
          ],
          "devices": [],
          "host_ip": "0.0.0.0",
          "host_port": 8085,
          "container_port": 8085,
          "has_tty": false,
          "network_config": "bridge"
        }
      }
    }
  }
}
