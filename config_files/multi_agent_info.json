{
  "sub_agents": {
    "image_agent": {
      "description": "Image reasoning agent that selects an on-board vision model and triggers gateway execution.",
      "capabilities": [
        "object_detection",
        "image_classification",
        "image_reasoning"
      ],
      "startup_overhead": {
        "RK3588": {
          "cpu_usage": 0.03,
          "mem_usage": 0.02,
          "xpu_usage": 0.4
        },
        "ATLAS_H": {
          "cpu_usage": 0.04,
          "mem_usage": 0.03,
          "xpu_usage": 0.4
        }
      },
      "tools": {
        "YoloV5": {
          "task_type": "YoloV5",
          "tool_kind": "vision_model",
          "capabilities": [
            "object_detection",
            "multi_object_detection",
            "bounding_box_estimation"
          ],
          "description": "Fast object detection model for locating multiple targets in an image."
        },
        "ResNet50": {
          "task_type": "ResNet50",
          "tool_kind": "vision_model",
          "capabilities": [
            "image_classification",
            "single_label_classification"
          ],
          "description": "Image classification model with stronger accuracy but higher cost than MobileNet."
        },
        "MobileNet": {
          "task_type": "MobileNet",
          "tool_kind": "vision_model",
          "capabilities": [
            "image_classification",
            "lightweight_classification",
            "fast_inference"
          ],
          "description": "Lightweight image classification model optimized for speed and lower overhead."
        }
      },
      "runtime": {
        "RK3588": {
          "container_name": "image_agent_qwen3_1_7b",
          "image": "qwen3_1.7b_docker:latest",
          "startup_timeout_sec": 60,
          "cmds": [
            "bash",
            "/workspace/multi-agent/rk_server/image_agent.sh"
          ],
          "args": [],
          "host_config_privileged": true,
          "env": [
            "PYTHONUNBUFFERED=1",
            "LLM_API_URL=http://127.0.0.1:8081/v1/chat/completions",
            "IMAGE_AGENT_PORT=8083",
            "RKLLM_MODEL_PATH=/models/Qwen3-1.7B-rk3588-w8a8.rkllm",
            "RKLLM_TARGET_PLATFORM=rk3588"
          ],
          "host_config_binds": [
            "/root/edge-cluster-scheduler/multi-agent:/workspace/multi-agent",
            "/root/edge-cluster-scheduler/config_files:/workspace/config_files",
            "/dev/dri:/dev/dri",
            "/proc/device-tree:/proc/device-tree:ro",
            "/root/models/Qwen3-1.7B-rk3588-w8a8.rkllm:/models/Qwen3-1.7B-rk3588-w8a8.rkllm"
          ],
          "devices": [],
          "host_ip": "0.0.0.0",
          "host_port": 8083,
          "container_port": 8083,
          "has_tty": false,
          "network_config": "bridge"
        },
        "ATLAS_H": {
          "container_name": "image_agent_qwen_ascend_atlas_h",
          "image": "qwen-openai-server:orangepi",
          "startup_timeout_sec": 60,
          "cmds": [
            "bash",
            "/workspace/multi-agent/ascend_server/image_agent.sh"
          ],
          "args": [],
          "host_config_privileged": true,
          "env": [
            "PYTHONUNBUFFERED=1",
            "ASCEND_VISIBLE_DEVICES=0",
            "ASCEND_RT_VISIBLE_DEVICES=0",
            "ASCEND_ALLOW_LINK=True",
            "MODEL_DIR=/models/DeepSeek-R1-Distill-Qwen-1.5B_server",
            "LLM_HOST=127.0.0.1",
            "LLM_PORT=8081",
            "LLM_MODEL_NAME=deepseek-r1-distill-qwen-1.5b",
            "MAX_SEQ_LEN=8192",
            "MAX_GEN_TOKEN=8192",
            "START_LOCAL_LLM=1",
            "IMAGE_AGENT_PORT=8083",
            "GATEWAY_HOST=192.168.58.3",
            "GATEWAY_PORT=6666"
          ],
          "host_config_binds": [
            "/root/Harmony-TSC/multi-agent:/workspace/multi-agent",
            "/root/Harmony-TSC/config_files:/workspace/config_files",
            "/root/models/DeepSeek-R1-Distill-Qwen-1.5B_server:/models/DeepSeek-R1-Distill-Qwen-1.5B_server:ro",
            "/dev/davinci_manager_docker:/dev/davinci_manager",
            "/usr/local/Ascend:/usr/local/Ascend:ro",
            "/usr/local/Ascend/driver:/usr/local/Ascend/driver",
            "/usr/local/Ascend/driver/lib64:/usr/local/Ascend/driver/lib64",
            "/usr/local/Ascend/ascend-toolkit:/usr/local/Ascend/ascend-toolkit:ro",
            "/var/davinci:/var/davinci",
            "/var/davinci/driver:/var/davinci/driver",
            "/usr/lib64:/usr/lib64:ro",
            "/usr/lib64/aicpu_kernels:/usr/lib64/aicpu_kernels:ro",
            "/etc/sys_version.conf:/etc/sys_version.conf:ro",
            "/etc/hdcBasic.cfg:/etc/hdcBasic.cfg:ro",
            "/etc/ascend_install.info:/etc/ascend_install.info:ro",
            "/etc/slog.conf:/etc/slog.conf:ro",
            "/var/slogd:/var/slogd",
            "/var/dmp_daemon:/var/dmp_daemon",
            "/var/log/ascend_seclog:/var/log/ascend_seclog",
            "/usr/local/sbin/npu-smi:/usr/local/sbin/npu-smi:ro",
            "/usr/lib64/libaicpu_processer.so:/usr/lib64/libaicpu_processer.so:ro",
            "/usr/lib64/libaicpu_prof.so:/usr/lib64/libaicpu_prof.so:ro",
            "/usr/lib64/libaicpu_sharder.so:/usr/lib64/libaicpu_sharder.so:ro",
            "/usr/lib64/libadump.so:/usr/lib64/libadump.so:ro",
            "/usr/lib64/libtsd_eventclient.so:/usr/lib64/libtsd_eventclient.so:ro",
            "/usr/lib64/libaicpu_scheduler.so:/usr/lib64/libaicpu_scheduler.so:ro",
            "/usr/lib64/libdcmi.so:/usr/lib64/libdcmi.so:ro",
            "/usr/lib64/libmpi_dvpp_adapter.so:/usr/lib64/libmpi_dvpp_adapter.so:ro",
            "/usr/lib64/libstackcore.so:/usr/lib64/libstackcore.so:ro",
            "/usr/lib64/libc_sec.so:/usr/lib64/libc_sec.so:ro",
            "/usr/lib64/libdevmmap.so:/usr/lib64/libdevmmap.so:ro",
            "/usr/lib64/libdrvdsmi.so:/usr/lib64/libdrvdsmi.so:ro",
            "/usr/lib64/libslog.so:/usr/lib64/libslog.so:ro",
            "/usr/lib64/libmmpa.so:/usr/lib64/libmmpa.so:ro",
            "/usr/lib64/libascend_hal.so:/usr/lib64/libascend_hal.so:ro"
          ],
          "devices": [
            "/dev/davinci0",
            "/dev/ascend_manager",
            "/dev/svm0",
            "/dev/devmm_svm",
            "/dev/ts_aisle",
            "/dev/upgrade",
            "/dev/sys",
            "/dev/vdec",
            "/dev/vpc",
            "/dev/pngd",
            "/dev/venc",
            "/dev/dvpp_cmdlist",
            "/dev/log_drv"
          ],
          "host_ip": "0.0.0.0",
          "host_port": 8083,
          "container_port": 8083,
          "has_tty": false,
          "network_config": "bridge"
        }
      }
